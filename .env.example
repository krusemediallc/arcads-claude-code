# Copy this file to .env and fill in your credentials (never commit .env).
# Values with special characters ({, [, *, etc.) MUST be single-quoted.

# ── kie.ai API key (required) ────────────────────────────────────────────────
# Create a key at https://kie.ai/api-key
# The key is sent as an HTTP Bearer token: `Authorization: Bearer $KIE_API_KEY`.
KIE_API_KEY='your_kie_api_key_here'

# ── Optional ─────────────────────────────────────────────────────────────────
# Override the base URL if kie.ai provides a different host for your workspace.
# KIE_BASE_URL=https://api.kie.ai
