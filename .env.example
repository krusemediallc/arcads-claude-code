# Copy this file to .env and fill in your Arcads API key (never commit .env).

# Required: used as HTTP Basic auth username (password empty) unless Arcads docs say otherwise.
ARCADS_API_KEY=your_key_here

# Optional: client ID and pre-encoded Basic auth header (if your Arcads dashboard provides them).
# ARCADS_CLIENT_ID=your_client_id_here
# ARCADS_BASIC_AUTH=Basic <base64_encoded_credentials>

# Optional: override API host (default https://external-api.arcads.ai)
# ARCADS_BASE_URL=https://external-api.arcads.ai
